<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>تولد ریحان مبارک | هدیه ویژه</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #0a0f1e 0%, #0c1222 100%);
            font-family: 'Vazirmatn', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 1.5rem;
            color: #eef5ff;
        }

        @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600&display=swap');

        .card {
            max-width: 750px;
            width: 100%;
            background: rgba(18, 25, 45, 0.7);
            backdrop-filter: blur(12px);
            border-radius: 2.5rem;
            padding: 2rem 1.8rem;
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(120, 160, 255, 0.15);
            transition: all 0.3s ease;
            border: 1px solid rgba(80, 130, 255, 0.2);
        }

        h1 {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #FFF8E7, #B9E0FF);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-align: center;
            margin-bottom: 0.5rem;
        }

        .sub {
            text-align: center;
            color: #8e9fc3;
            margin-bottom: 2rem;
            border-bottom: 1px dashed #2a3550;
            display: inline-block;
            width: auto;
            margin-left: auto;
            margin-right: auto;
            padding-bottom: 0.5rem;
            font-size: 0.95rem;
        }

        .greeting-prompt {
            text-align: center;
            font-size: 1.2rem;
            font-weight: 500;
            margin-bottom: 1.8rem;
            color: #cbdffc;
        }

        .buttons-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            justify-content: center;
            margin-bottom: 2rem;
        }

        .char-btn {
            background: #111827;
            border: none;
            padding: 0.7rem 1.2rem;
            border-radius: 3rem;
            font-size: 1rem;
            font-weight: 600;
            color: #e2eaff;
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 5px 12px rgba(0, 0, 0, 0.3);
            border: 1px solid #2a3a60;
            font-family: inherit;
        }

        .char-btn img {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid #5f8eff;
        }

        .char-btn:hover {
            transform: translateY(-3px);
            background: #1f2a44;
            border-color: #5f8eff;
            box-shadow: 0 12px 20px rgba(0, 0, 0, 0.4);
        }

        .message-box {
            background: #0a0f1ad9;
            border-radius: 1.8rem;
            padding: 1.5rem;
            margin: 1rem 0 1rem 0;
            border-right: 5px solid #3b82f6;
            transition: all 0.25s;
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .message-avatar {
            flex-shrink: 0;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            overflow: hidden;
            border: 2px solid #8aadff;
            background: #1f2a44;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .message-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .message-content {
            flex: 1;
        }

        .message-text {
            font-size: 1rem;
            line-height: 1.7;
            color: #f0f3fc;
            font-weight: 400;
            text-align: justify;
        }

        .message-author {
            margin-top: 0.7rem;
            font-size: 0.8rem;
            color: #7e8fb0;
            text-align: left;
            font-style: italic;
        }

        .footer-note {
            text-align: center;
            font-size: 0.75rem;
            color: #5f6f8a;
            margin-top: 1.8rem;
            border-top: 1px solid #232e44;
            padding-top: 1.2rem;
        }

        .footer-note code {
            background: #00000040;
            padding: 0.2rem 0.5rem;
            border-radius: 12px;
            font-family: monospace;
            font-size: 0.8rem;
        }

        @media (max-width: 550px) {
            .card {
                padding: 1.3rem;
            }
            h1 {
                font-size: 1.6rem;
            }
            .message-avatar {
                width: 50px;
                height: 50px;
            }
            .char-btn img {
                width: 26px;
                height: 26px;
            }
        }
    </style>
</head>
<body>

<div class="card">
    <h1>✨ ریحان جان، تولدت مبارک ✨</h1>
    <div style="text-align: center;">
        <div class="sub">★ روایتی از جنس قلم و سایه ★</div>
    </div>

    <div class="greeting-prompt">
        🎁 کدام شخصیت امروز با تو هم‌نفس می‌شود؟
    </div>

    <div class="buttons-grid">
        <button class="char-btn" data-char="johan">
            <img src="images/johan.jpg" alt="یوهان" onerror="this.src='https://placehold.co/32x32?text=Johan'"> یوهان لیبرت
        </button>
        <button class="char-btn" data-char="raskol">
            <img src="images/raskolnikov.jpg" alt="راسکولنیکف" onerror="this.src='https://placehold.co/32x32?text=Raskol'"> راسکولنیکف
        </button>
        <button class="char-btn" data-char="sjw">
            <img src="images/sungjinwoo.jpg" alt="سونگ جین‌وو" onerror="this.src='https://placehold.co/32x32?text=SJW'"> سونگ جین‌وو
        </button>
    </div>

    <div class="message-box" id="messageBox">
        <div class="message-avatar" id="messageAvatar">
            <img src="https://placehold.co/70x70?text=?" alt="avatar">
        </div>
        <div class="message-content">
            <div class="message-text" id="messageText">
                یکی از شخصیت‌ها را انتخاب کن...<br>
                هرکدام حرفی برای دل تو دارند.
            </div>
            <div class="message-author" id="messageAuthor"></div>
        </div>
    </div>

    <div class="footer-note">
        💡 ایستر اگ: کنسول مرورگر را باز کن (F12) و تایپ کن <code>happyBirthday()</code>
    </div>
</div>

<script>
    // ==================================================
    // تنظیم مسیر عکس‌های شخصیت‌ها (برای بخش پیام)
    // لطفاً آدرس صحیح عکس‌های خود را در اینجا وارد کنید
    // ==================================================
    const charImages = {
        johan: "images/johan.jpg",
        raskol: "images/raskolnikov.jpg",
        sjw: "images/sungjinwoo.jpg"
    };

    // متن تبریک‌ها
    const messages = {
        johan: {
            text: "ریحان... جهان ما از رویاها و کابوس‌ها بافته شده. تو اما توانستی بی‌آنکه به تاریکی آلوده شوی، عمیق‌ترین لایه‌های داستان‌ها را درک کنی. تولدت مبارک؛ باشد که روایت زندگی‌ات همواره پر از معماهای شیرین باشد. – یوهان",
            author: "🎭 یوهان لیبرت (Monster)"
        },
        raskol: {
            text: "ریحان عزیز، «یادداشت‌های زیرزمینی» و «جنایت و مکافات» فقط کلمات نیستند، گوشه‌هایی از روح تو هستند. عبور از مرزهای اخلاقی و بازگشت به انسانیت، شاید سخت‌ترین ماجراست. اما تو یک سال دیگر را زیسته‌ای، بدون آنکه به کسی آسیب بزنی. این بزرگ‌ترین پیروزی است. تولدت گرامی باد. – راسکولنیکف",
            author: "📖 راسکولنیکف (جنایت و مکافات)"
        },
        sjw: {
            text: "ریحان، هر روز صبح مثل باز شدن یک «دروازه» جدید است. تو شکارچی لحظه‌هایی، که می‌توانی قوی‌تر از دیروز باشی. هیچ سایه‌ای نمی‌تواند جلوی اراده‌ی کسی را بگیرد که عاشق کتاب و انیمه است. امروز روز توست، نفس عمیق بکش و بدرخش. تولدت مبارک، شکارچی بی‌همتا. – سونگ جین‌وو",
            author: "⚔️ سونگ جین‌وو (Solo Leveling)"
        }
    };

    // المان‌ها
    const messageBox = document.getElementById('messageBox');
    const messageTextElem = document.getElementById('messageText');
    const messageAuthorElem = document.getElementById('messageAuthor');
    const messageAvatarImg = document.querySelector('#messageAvatar img');

    function showMessage(characterId) {
        const msg = messages[characterId];
        if(!msg) return;
        
        // تغییر عکس آواتار
        const imgPath = charImages[characterId];
        if(imgPath) {
            messageAvatarImg.src = imgPath;
            messageAvatarImg.onerror = function() {
                this.src = "https://placehold.co/70x70?text=?";
            };
        } else {
            messageAvatarImg.src = "https://placehold.co/70x70?text=?";
        }

        // انیمیشن محو و ظاهر شدن
        messageBox.style.opacity = '0';
        setTimeout(() => {
            messageTextElem.innerHTML = msg.text.replace(/\n/g, '<br>');
            messageAuthorElem.innerHTML = msg.author;
            messageBox.style.opacity = '1';
        }, 120);
    }

    // اتصال رویداد به دکمه‌ها
    const btns = document.querySelectorAll('.char-btn');
    btns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            const charId = btn.getAttribute('data-char');
            showMessage(charId);
        });
    });

    // =======================
    // EASTER EGG (console command)
    // =======================
    window.happyBirthday = function() {
        // ساخت کانفتی
        const canvas = document.createElement('canvas');
        canvas.style.position = 'fixed';
        canvas.style.top = '0';
        canvas.style.left = '0';
        canvas.style.width = '100%';
        canvas.style.height = '100%';
        canvas.style.pointerEvents = 'none';
        canvas.style.zIndex = '9999';
        document.body.appendChild(canvas);
        
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        
        let particles = [];
        const colors = ['#ffd966', '#ffb347', '#ff6b6b', '#6b5bff', '#4cd964', '#ff9f4a'];
        
        for(let i = 0; i < 150; i++) {
            particles.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height - canvas.height,
                size: Math.random() * 8 + 4,
                color: colors[Math.floor(Math.random() * colors.length)],
                speedY: Math.random() * 6 + 4,
                speedX: (Math.random() - 0.5) * 3,
                rotation: Math.random() * 360,
                spin: (Math.random() - 0.5) * 8
            });
        }
        
        let animationId;
        let startTime = performance.now();
        
        function drawConfetti(now) {
            if(now - startTime > 3500) {
                cancelAnimationFrame(animationId);
                canvas.remove();
                return;
            }
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            for(let p of particles) {
                ctx.save();
                ctx.translate(p.x, p.y);
                ctx.rotate(p.rotation * Math.PI/180);
                ctx.fillStyle = p.color;
                ctx.fillRect(-p.size/2, -p.size/2, p.size, p.size);
                ctx.restore();
                p.y += p.speedY;
                p.x += p.speedX;
                p.rotation += p.spin;
                if(p.y > canvas.height + 50) {
                    p.y = -30;
                    p.x = Math.random() * canvas.width;
                }
                if(p.x < -50) p.x = canvas.width + 30;
                if(p.x > canvas.width + 50) p.x = -30;
            }
            animationId = requestAnimationFrame(drawConfetti);
        }
        
        animationId = requestAnimationFrame(drawConfetti);
        
        // پیام مخفی
        const secretDiv = document.createElement('div');
        secretDiv.innerText = '🎂 راز پنهان: بهترین هدیه، خودِ تویی ریحان جان 🎂';
        secretDiv.style.position = 'fixed';
        secretDiv.style.bottom = '20px';
        secretDiv.style.left = '20px';
        secretDiv.style.backgroundColor = '#000000aa';
        secretDiv.style.backdropFilter = 'blur(8px)';
        secretDiv.style.color = '#fff7cf';
        secretDiv.style.padding = '12px 18px';
        secretDiv.style.borderRadius = '40px';
        secretDiv.style.fontSize = '0.9rem';
        secretDiv.style.zIndex = '10000';
        secretDiv.style.fontFamily = 'monospace';
        secretDiv.style.border = '1px solid gold';
        secretDiv.style.pointerEvents = 'none';
        document.body.appendChild(secretDiv);
        setTimeout(() => secretDiv.remove(), 4200);
        
        console.log("%c🎂 تولدت مبارک ریحان! 🎂", "color: #ffaa44; font-size: 16px; font-weight: bold;");
        console.log("هدیه از طرف کسی که می‌داند عاشق کتاب و انیمه‌ای... باشد که لحظه‌هایت پر از ماجراهای ناب باشد.");
        return "ریحان جان، تو قهرمان داستان خودت باش!";
    };
    
    // راهنمایی در کنسول
    console.log("%c✨ ریحان جان، به صفحه‌ی شخصیت‌ها خوش آمدی. تایپ کن: happyBirthday() ✨", "color: #92b9ff; font-size: 12px;");
</script>
</body>
</html>